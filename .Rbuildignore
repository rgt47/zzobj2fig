# renv
^renv$
^renv\.lock$

# License files (separate from DESCRIPTION License field)
^LICENSE\.md$
^CODE_OF_CONDUCT\.md$

# GitHub
^\.github$

# Documentation build artifacts
^doc$
^Meta$

# RStudio project files
^.*\.Rproj$
^\.Rproj\.user$

# zzcollab
^\.zzcollab$
^Dockerfile$
^Makefile$
^docs$
^analysis$
^CLAUDE\.md$
^ZZCOLLAB_USER_GUIDE\.md$

# zzvim-R temp files
^\.zz.*\.R$

# Local config
^\.Rprofile\.local$

# Cache
^\.cache$

# Claude Code
^\.claude$

# Vignette build artifacts (re-rendered each build)
^vignettes/.*\.html$
^vignettes/.*\.pdf$
^vignettes/.*\.aux$
^vignettes/.*\.tex$
^vignettes/.*\.log$
^vignettes/.*_files$
^vignettes/basic_output$
^vignettes/color_demo$
^vignettes/output$
^vignettes/tables$
